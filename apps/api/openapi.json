{
  "components": {
    "schemas": {
      "AuthStateResponse": {
        "properties": {
          "session_expires_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Expires At"
          },
          "user": {
            "$ref": "#/components/schemas/UserOut"
          }
        },
        "required": [
          "user",
          "session_expires_at"
        ],
        "title": "AuthStateResponse",
        "type": "object"
      },
      "DevSessionRequest": {
        "properties": {
          "password": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "maxLength": 32,
            "minLength": 3,
            "pattern": "^[A-Za-z0-9_-]+$",
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "DevSessionRequest",
        "type": "object"
      },
      "DevSessionResponse": {
        "properties": {
          "expires_in": {
            "title": "Expires In",
            "type": "integer"
          },
          "token": {
            "title": "Token",
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserOut"
          }
        },
        "required": [
          "token",
          "expires_in",
          "user"
        ],
        "title": "DevSessionResponse",
        "type": "object"
      },
