          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VoiceTokenResponse": {
        "properties": {
          "expires_in": {
            "title": "Expires In",
            "type": "integer"
          },
          "identity": {
            "title": "Identity",
            "type": "string"
          },
          "room": {
            "title": "Room",
            "type": "string"
          },
          "token": {
            "title": "Token",
            "type": "string"
          },
          "ws_url": {
            "title": "Ws Url",
            "type": "string"
          }
        },
        "required": [
          "token",
          "ws_url",
          "room",
          "identity",
          "expires_in"
        ],
        "title": "VoiceTokenResponse",
        "type": "object"
      }
    }
