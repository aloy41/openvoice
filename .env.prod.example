# Openvoice PRODUCTION environment configuration.
# Copy to `.env.prod` and fill in EVERY value. `.env.prod` is gitignored;
# NEVER commit real secrets.
#
# Generate strong secrets with one of:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Deploy with:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- TLS / domain -----------------------------------------------------------
# A real domain that resolves (A/AAAA) to this host. Caddy obtains and renews a
# Let's Encrypt certificate for it automatically; ports 80 and 443 must be
# reachable from the internet for the ACME challenge.
OPENVOICE_DOMAIN=chat.example.com
# Email for the ACME account / expiry notices.
OPENVOICE_ACME_EMAIL=admin@example.com

# --- Core -------------------------------------------------------------------
# Session/CSRF signing key. REQUIRED, minimum 32 characters. Rotating it
# invalidates all existing sessions. Generate a fresh one — never reuse dev.
OPENVOICE_SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_secret

# Uvicorn worker processes. Rule of thumb: (2 x CPU cores) capped by memory.
UVICORN_WORKERS=2

# --- Database ---------------------------------------------------------------
# Not published to the host in prod (private compose network only), but still
# use a strong password — it protects backups and any future network exposure.
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# --- Backups ----------------------------------------------------------------
# Interval between automatic pg_dump backups (seconds; default daily) and how
# many days of dumps to keep.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP_DAYS=14

# --- LiveKit ----------------------------------------------------------------
# API key/secret shared between the API and the LiveKit server. The secret must
# be at least 32 characters. Generate fresh values for production.
LIVEKIT_API_KEY=CHANGE_ME_livekit_key
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret_min_32_chars

# Public IP address LiveKit advertises in ICE candidates. MUST be the host's
# routable/public IP for real clients to connect (not 127.0.0.1).
LIVEKIT_NODE_IP=CHANGE_ME_public_ip
