# Openvoice development environment configuration.
# Copy to `.env` and fill in the secrets below. The `.env` file is gitignored;
# NEVER commit real secrets.
#
# Generate strong secrets with one of:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Core -------------------------------------------------------------------
# development | test | production. The API refuses to start in production with
# dev auth enabled.
OPENVOICE_ENVIRONMENT=development

# Signing key for development session tokens. REQUIRED, minimum 32 characters.
# Generate one (see above) — do not reuse the example value.
OPENVOICE_SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_secret

# --- Development authentication --------------------------------------------
# Dev-only shared password login. Must be OFF in production; the API enforces
# this at startup.
OPENVOICE_DEV_AUTH_ENABLED=true
# Minimum 12 characters. Anyone with this password can join the dev stack.
OPENVOICE_DEV_AUTH_PASSWORD=CHANGE_ME_dev_password

# --- Databases (compose-internal defaults; change for any exposed setup) ----
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# --- LiveKit ----------------------------------------------------------------
# API key/secret pair shared between the API service and the LiveKit server.
# The secret must be at least 32 characters. These are placeholders for local
# development only.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret_min_32_chars

# How browsers reach LiveKit signaling. "origin" (recommended) routes voice
# through the same port and certificate as the page itself (Caddy proxies
# /rtc*), so LAN devices only ever accept ONE certificate. Set an explicit
# ws:// or wss:// URL only if LiveKit is hosted on a separate address.
OPENVOICE_LIVEKIT_WS_URL=origin

# IP address LiveKit advertises in ICE candidates. 127.0.0.1 works for
# same-machine calls. Set your machine's LAN IP (e.g. 192.168.1.20) to test
# from other devices on your network or to validate TURN relay
# (RUN_RELAY=1 e2e) — ICE cannot complete through a loopback relay.
LIVEKIT_NODE_IP=127.0.0.1
